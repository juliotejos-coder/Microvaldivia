import pandas as pd
import json

# =========================
# CONFIGURACIÓN
# =========================
ROUTES_FILE = "routes.txt"      # GTFS original
OUTPUT_FILE = "data/index.json" # Archivo que se reemplazará

# Paleta de colores simple (se reutiliza si hay más rutas)
COLORS = [
    "#1D4ED8", "#15803D", "#C1121F",
    "#7C3AED", "#EA580C", "#0F766E"
]

# =========================
# CARGA DE ROUTES.TXT
# =========================
routes = pd.read_csv(
    ROUTES_FILE,
    dtype=str,
    usecols=["route_id", "route_short_name", "route_long_name"]
)

routes = routes.sort_values("route_short_name")

# =========================
# CONSTRUIR INDEX.JSON
# =========================
index = []

for i, row in routes.iterrows():
    route_id = row["route_id"]
    short_name = row["route_short_name"]
    long_name = row["route_long_name"]

    index.append({
        "route_id": route_id,
        "route_short_name": short_name,
        "route_long_name": long_name,
        "archivo": f"ruta_{route_id}.geojson",
        "color": COLORS[len(index) % len(COLORS)]
    })

# =========================
# GUARDAR RESULTADO
# =========================
with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
    json.dump(index, f, ensure_ascii=False, indent=2)

print("✅ index.json generado correctamente")
